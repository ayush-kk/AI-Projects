# Application
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=true

# JWT Authentication
JWT_SECRET=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=sqlite:///./app.db

# CORS
CORS_ORIGINS=http://localhost:5173

# Ollama (Local AI Models)
OLLAMA_BASE_URL=http://localhost:11434

# Groq (Free Cloud AI - get key at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# HuggingFace (Image Generation - get token at https://huggingface.co/settings/tokens)
HUGGINGFACE_TOKEN=hf_your_token_here

# Whisper (Speech-to-Text)
WHISPER_MODEL_SIZE=base

# File Storage
UPLOAD_DIR=./storage/uploads
GENERATED_DIR=./storage/generated
MAX_UPLOAD_SIZE_MB=50
